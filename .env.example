# ── OAuth mode (original upstream — requires an Evernote developer key) ────────
EVERNOTE_CONSUMER_KEY=your-consumer-key
EVERNOTE_CONSUMER_SECRET=your-consumer-secret
EVERNOTE_ENVIRONMENT=production
OAUTH_CALLBACK_PORT=3000

# ── Evertoken mode (Docker / no developer key needed) ──────────────────────────
# Run "evertoken.exe new" on your Windows machine, then fill in these values.

EVERNOTE_AUTH_MODE=evertoken

# From "Refresh Token (JWT)" line — valid ~1 year, rotates on each refresh
EVERNOTE_SEED_NRT=eyJ...

# From "Client ID" line — stable for your Evernote installation
EVERNOTE_SEED_NCI=3FE74DA6-...

# Generate once and keep stable:  node -e "console.log(require('crypto').randomUUID())"
EVERNOTE_DEVICE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Device fingerprint (defaults match a Windows desktop client — change only if needed)
# EVERNOTE_DEVICE_DESCRIPTION=Computer
# EVERNOTE_APP_VERSION=11.12.2
# EVERNOTE_OS_PLATFORM=win32
# EVERNOTE_OS_RELEASE=10.0

# State file path — must point to a Docker volume mount in containerised deployments
# MCP_EVERNOTE_STATE_PATH=/data/mcp-evernote/state.json

# ── mcp-auth-proxy (Docker only) ───────────────────────────────────────────────
MCP_PASSWORD=changeme
MCP_EXTERNAL_URL=https://mcp-evernote.yourdomain.com